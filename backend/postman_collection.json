{
  "info": {
    "name": "Car Dealership API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userToken", "value": "" },
    { "key": "adminToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        { "name": "Register", "event": [{"listen": "test","script": {"exec": ["var json = pm.response.json();","pm.collectionVariables.set('userToken', json.token);"],"type": "text/javascript"}}], "request": { "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw","raw": "{\"username\":\"testuser\",\"email\":\"test@example.com\",\"password\":\"password123\"}"}, "url": {"raw": "{{baseUrl}}/api/auth/register","host": ["{{baseUrl}}"],"path": ["api","auth","register"]}}},
        { "name": "Login (User)", "event": [{"listen": "test","script": {"exec": ["var json = pm.response.json();","pm.collectionVariables.set('userToken', json.token);"],"type": "text/javascript"}}], "request": { "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw","raw": "{\"username\":\"alice\",\"password\":\"password123\"}"}, "url": {"raw": "{{baseUrl}}/api/auth/login","host": ["{{baseUrl}}"],"path": ["api","auth","login"]}}},
        { "name": "Login (Admin)", "event": [{"listen": "test","script": {"exec": ["var json = pm.response.json();","pm.collectionVariables.set('adminToken', json.token);"],"type": "text/javascript"}}], "request": { "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw","raw": "{\"username\":\"admin\",\"password\":\"admin123\"}"}, "url": {"raw": "{{baseUrl}}/api/auth/login","host": ["{{baseUrl}}"],"path": ["api","auth","login"]}}}
      ]
    },
    {
      "name": "Categories",
      "item": [
        { "name": "Get All", "request": { "method": "GET", "header": [{"key": "Authorization","value": "Bearer {{userToken}}"}], "url": {"raw": "{{baseUrl}}/api/categories","host": ["{{baseUrl}}"],"path": ["api","categories"]}}},
        { "name": "Create (Admin)", "request": { "method": "POST", "header": [{"key": "Content-Type","value": "application/json"},{"key": "Authorization","value": "Bearer {{adminToken}}"}], "body": {"mode": "raw","raw": "{\"name\":\"Luxury\",\"description\":\"Premium vehicles\"}"}, "url": {"raw": "{{baseUrl}}/api/categories","host": ["{{baseUrl}}"],"path": ["api","categories"]}}},
        { "name": "Delete (Admin)", "request": { "method": "DELETE", "header": [{"key": "Authorization","value": "Bearer {{adminToken}}"}], "url": {"raw": "{{baseUrl}}/api/categories/1","host": ["{{baseUrl}}"],"path": ["api","categories","1"]}}}
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        { "name": "Get All", "request": { "method": "GET", "header": [{"key": "Authorization","value": "Bearer {{userToken}}"}], "url": {"raw": "{{baseUrl}}/api/vehicles?page=0&size=10","host": ["{{baseUrl}}"],"path": ["api","vehicles"],"query": [{"key":"page","value":"0"},{"key":"size","value":"10"}]}}},
        { "name": "Search", "request": { "method": "GET", "header": [{"key": "Authorization","value": "Bearer {{userToken}}"}], "url": {"raw": "{{baseUrl}}/api/vehicles/search?make=Toyota&category=Sedan","host": ["{{baseUrl}}"],"path": ["api","vehicles","search"],"query": [{"key":"make","value":"Toyota"},{"key":"category","value":"Sedan"},{"key":"minPrice","value":"20000"},{"key":"maxPrice","value":"30000"}]}}},
        { "name": "Get By ID", "request": { "method": "GET", "header": [{"key": "Authorization","value": "Bearer {{userToken}}"}], "url": {"raw": "{{baseUrl}}/api/vehicles/1","host": ["{{baseUrl}}"],"path": ["api","vehicles","1"]}}},
        { "name": "Create (Admin)", "request": { "method": "POST", "header": [{"key": "Content-Type","value": "application/json"},{"key": "Authorization","value": "Bearer {{adminToken}}"}], "body": {"mode": "raw","raw": "{\"make\":\"Toyota\",\"model\":\"Camry\",\"category\":\"Sedan\",\"price\":25000,\"quantity\":10}"}, "url": {"raw": "{{baseUrl}}/api/vehicles","host": ["{{baseUrl}}"],"path": ["api","vehicles"]}}},
        { "name": "Update (Admin)", "request": { "method": "PUT", "header": [{"key": "Content-Type","value": "application/json"},{"key": "Authorization","value": "Bearer {{adminToken}}"}], "body": {"mode": "raw","raw": "{\"make\":\"Toyota\",\"model\":\"Camry LE\",\"category\":\"Sedan\",\"price\":26000,\"quantity\":12}"}, "url": {"raw": "{{baseUrl}}/api/vehicles/1","host": ["{{baseUrl}}"],"path": ["api","vehicles","1"]}}},
        { "name": "Delete (Admin)", "request": { "method": "DELETE", "header": [{"key": "Authorization","value": "Bearer {{adminToken}}"}], "url": {"raw": "{{baseUrl}}/api/vehicles/1","host": ["{{baseUrl}}"],"path": ["api","vehicles","1"]}}}
      ]
    },
    {
      "name": "Inventory",
      "item": [
        { "name": "Purchase", "request": { "method": "POST", "header": [{"key": "Content-Type","value": "application/json"},{"key": "Authorization","value": "Bearer {{userToken}}"}], "body": {"mode": "raw","raw": "{\"quantity\":2}"}, "url": {"raw": "{{baseUrl}}/api/vehicles/2/purchase","host": ["{{baseUrl}}"],"path": ["api","vehicles","2","purchase"]}}},
        { "name": "Restock (Admin)", "request": { "method": "POST", "header": [{"key": "Content-Type","value": "application/json"},{"key": "Authorization","value": "Bearer {{adminToken}}"}], "body": {"mode": "raw","raw": "{\"quantity\":5}"}, "url": {"raw": "{{baseUrl}}/api/vehicles/2/restock","host": ["{{baseUrl}}"],"path": ["api","vehicles","2","restock"]}}},
        { "name": "Over-Purchase (expect 400)", "request": { "method": "POST", "header": [{"key": "Content-Type","value": "application/json"},{"key": "Authorization","value": "Bearer {{userToken}}"}], "body": {"mode": "raw","raw": "{\"quantity\":999}"}, "url": {"raw": "{{baseUrl}}/api/vehicles/2/purchase","host": ["{{baseUrl}}"],"path": ["api","vehicles","2","purchase"]}}}
      ]
    },
    {
      "name": "Errors",
      "item": [
        { "name": "No Token (expect 401)", "request": { "method": "GET", "url": {"raw": "{{baseUrl}}/api/vehicles","host": ["{{baseUrl}}"],"path": ["api","vehicles"]}}},
        { "name": "User Forbidden (expect 403)", "request": { "method": "DELETE", "header": [{"key": "Authorization","value": "Bearer {{userToken}}"}], "url": {"raw": "{{baseUrl}}/api/vehicles/2","host": ["{{baseUrl}}"],"path": ["api","vehicles","2"]}}},
        { "name": "Duplicate Register (expect 409)", "request": { "method": "POST", "header": [{"key": "Content-Type","value": "application/json"}], "body": {"mode": "raw","raw": "{\"username\":\"admin\",\"email\":\"dup@test.com\",\"password\":\"password123\"}"}, "url": {"raw": "{{baseUrl}}/api/auth/register","host": ["{{baseUrl}}"],"path": ["api","auth","register"]}}}
      ]
    }
  ]
}
